{
  "env": { "browser": true, "es2021": true },
  "parserOptions": { "sourceType": "module" },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "eqeqeq": "warn",
    "no-var": "error",
    "prefer-const": "warn"
  },
  "overrides": [
    {
      "files": ["api/**/*.js"],
      "env": { "node": true, "browser": false },
      "parserOptions": { "sourceType": "module" }
    }
  ]
}
